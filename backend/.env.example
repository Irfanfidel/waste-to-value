# ── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=ecomanage_super_secret_jwt_key_change_this_in_production

# ── Database ──────────────────────────────────────────────────────────────────
# OPTION A: MongoDB Atlas (production — data persists forever)
# Paste your Atlas connection string below and remove the localhost line
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/waste-to-value?retryWrites=true&w=majority

# OPTION B: Local MongoDB (if installed on your machine)
# MONGODB_URI=mongodb://localhost:27017/waste-to-value

# OPTION C: Leave blank — auto-uses embedded in-memory DB (data resets on restart)
MONGODB_URI=mongodb://localhost:27017/waste-to-value

# ── Email (optional — uses Ethereal test account if not set) ─────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
